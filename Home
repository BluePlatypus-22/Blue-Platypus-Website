<!-- ════════════════════ HOME ════════════════════ -->
<div id="page-home" class="page active">

  <!-- HERO -->
  <div class="hero">
    <!-- Decorative background platypus watermark -->
    <svg class="hero-bg-svg" viewBox="0 0 340 280" fill="none" aria-hidden="true">
      <!-- large platypus silhouette, white ultra-transparent -->
      <ellipse cx="200" cy="170" rx="105" ry="80" fill="rgba(255,255,255,0.04)"/>
      <circle  cx="95"  cy="120" r="72"          fill="rgba(255,255,255,0.04)"/>
      <path d="M28 135C5 122 -8 155 10 168C28 181 90 150 90 140C90 128 56 128 28 135Z" fill="rgba(255,255,255,0.04)"/>
      <path d="M290 182C325 160 338 200 320 212C302 222 290 190 290 182Z"              fill="rgba(255,255,255,0.04)"/>
      <!-- eye accent -->
      <circle cx="73" cy="102" r="15" fill="rgba(0,180,216,0.08)"/>
      <!-- orbit rings -->
      <circle cx="170" cy="140" r="130" fill="none" stroke="rgba(0,180,216,0.06)" stroke-width="1"/>
      <circle cx="170" cy="140" r="90"  fill="none" stroke="rgba(0,180,216,0.06)" stroke-width="1"/>
    </svg>

    <div class="hero-tag">Anonymous · Merit-Based · Fractional Executive Matching</div>
    <h1>The only fractional matching platform that leads with <span>merit,</span> not résumé theater.</h1>
    <p>We match companies and fractional executives on capability — not credentials, title inflation, or logo soup. Identity stays anonymous until both sides confirm fit.</p>
    <div class="hero-cta">
      <a href="#" class="btn-primary" onclick="showPage('register'); return false;">Take the Assessment</a>
      <a href="#" class="btn-outline"  onclick="showPage('how'); return false;">How It Works</a>
