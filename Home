<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blue Platypus | Fractional Talent Matching</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy:       #1a2e4a;
      --navy-dark:  #0f1e31;
      --teal:       #00b4d8;
      --teal-light: #90e0ef;
      --teal-dark:  #0096b5;
      --white:      #ffffff;
      --off-white:  #f5f8fb;
      --gray-100:   #edf1f7;
      --gray-300:   #c3cdd9;
      --gray-500:   #6b7a92;
      --gray-700:   #3d4f6a;
      --text:       #1a2540;
      --radius:     10px;
      --shadow:     0 4px 24px rgba(27,42,74,.10);
      --shadow-lg:  0 8px 40px rgba(27,42,74,.16);
    }
    body { font-family:'Segoe UI',system-ui,-apple-system,sans-serif; color:var(--text); background:var(--white); line-height:1.65; }

    /* NAV */
    nav {
      position:sticky; top:0; z-index:100;
      background:var(--navy-dark);
      display:flex; align-items:center; justify-content:space-between;
      padding:0 2rem; height:68px;
      box-shadow:0 2px 16px rgba(0,0,0,.28);
    }
    .nav-brand {
      display:flex; align-items:center; gap:12px;
      text-decoration:none; color:var(--white);
      font-size:1.15rem; font-weight:700; letter-spacing:.02em;
    }
    .nav-links { display:flex; align-items:center; gap:1.5rem; }
    .nav-links a { color:var(--teal-light); text-decoration:none; font-size:.9rem; font-weight:500; transition:color .2s; }
    .nav-links a:hover { color:var(--white); }
    .nav-btn { background:var(--teal); color:var(--navy-dark) !important; padding:.45rem 1.2rem; border-radius:6px; font-weight:700 !important; transition:background .2s !important; }
    .nav-btn:hover { background:var(--teal-light) !important; }

    /* PAGES */
    .page { display:none; }
    .page.active { display:block; }

    /* HERO */
    .hero {
      background:linear-gradient(140deg, var(--navy-dark) 0%, var(--navy) 55%, #1b3a5c 100%);
      color:var(--white); padding:5.5rem 2rem 5rem;
      text-align:center; position:relative; overflow:hidden;
    }
    .hero-bg-svg {
      position:absolute; right:-30px; top:50%; transform:translateY(-50%);
      height:440px; width:auto; pointer-events:none; opacity:1;
    }
    .hero-tag {
      display:inline-block; background:rgba(0,180,216,.18); color:var(--teal-light);
      border:1px solid rgba(0,180,216,.35);
      font-size:.8rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
      padding:.3rem 1rem; border-radius:20px; margin-bottom:1.4rem;
    }
    .hero h1 { font-size:clamp(2rem,5vw,3.4rem); font-weight:800; line-height:1.15; margin-bottom:1.2rem; }
    .hero h1 span { color:var(--teal); }
    .hero p { font-size:1.1rem; color:rgba(255,255,255,.78); max-width:600px; margin:0 auto 2.4rem; }
    .hero-cta { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }

    .btn-primary {
      background:var(--teal); color:var(--navy-dark);
      border:none; padding:.85rem 2rem; border-radius:8px;
      font-size:1rem; font-weight:700; cursor:pointer;
      text-decoration:none; display:inline-block;
      box-shadow:0 4px 16px rgba(0,180,216,.35);
      transition:background .2s, transform .15s, box-shadow .2s;
    }
    .btn-primary:hover { background:var(--teal-dark); transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,180,216,.45); }
    .btn-outline {
      background:transparent; color:var(--white);
      border:2px solid rgba(255,255,255,.4); padding:.83rem 2rem;
      border-radius:8px; font-size:1rem; font-weight:600;
      cursor:pointer; text-decoration:none; display:inline-block;
      transition:border-color .2s, background .2s;
    }
    .btn-outline:hover { border-color:var(--white); background:rgba(255,255,255,.08); }

    /* TRUST BAR */
    .trust-bar { background:var(--off-white); border-bottom:1px solid var(--gray-100); padding:1.2rem 2rem; text-align:center; }
    .trust-bar p { font-size:.88rem; color:var(--gray-500); }
    .trust-bar strong { color:var(--navy); }

    /* SECTIONS */
    section { padding:5rem 2rem; }
    .section-inner { max-width:1080px; margin:0 auto; }
    .section-label { color:var(--teal-dark); font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; margin-bottom:.5rem; }
    .section-title { font-size:clamp(1.6rem,3vw,2.3rem); font-weight:800; color:var(--navy); margin-bottom:1rem; line-height:1.2; }
    .section-sub { color:var(--gray-500); font-size:1rem; max-width:560px; }
    .center { text-align:center; }
    .center .section-sub { margin:0 auto; }

    /* HOW WE WORK section */
    .how { background:var(--off-white); }
    .steps { display:grid; grid-template-columns:repeat(auto-fit,minmax(270px,1fr)); gap:1.6rem; margin-top:3rem; }
    .step {
      background:var(--white); border-radius:var(--radius);
      padding:2.2rem 1.8rem; box-shadow:var(--shadow);
      border:1px solid var(--gray-100); position:relative;
      transition:box-shadow .2s, transform .2s;
    }
    .step:hover { box-shadow:var(--shadow-lg); transform:translateY(-4px); }
    .step-num { position:absolute; top:1.4rem; right:1.4rem; font-size:3rem; font-weight:900; color:var(--gray-100); line-height:1; user-select:none; }
    .step-icon {
      width:58px; height:58px; border-radius:14px;
      background:linear-gradient(135deg, var(--teal) 0%, #006fa3 100%);
      display:flex; align-items:center; justify-content:center;
      margin-bottom:1.2rem;
      box-shadow:0 4px 12px rgba(0,180,216,.3);
    }
    .step h3 { font-size:1.1rem; font-weight:800; color:var(--navy); margin-bottom:.6rem; }
    .step p { font-size:.93rem; color:var(--gray-500); line-height:1.65; }

    /* ABOUT */
    .about-grid { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; }
    @media (max-width:720px) { .about-grid { grid-template-columns:1fr; gap:2.5rem; } }
    .about-text p { color:var(--gray-700); font-size:.97rem; margin-bottom:1rem; }
    .about-text .pillars { display:flex; flex-direction:column; gap:.65rem; margin-top:1.4rem; }
    .pillar { display:flex; align-items:flex-start; gap:.7rem; font-size:.93rem; color:var(--navy); line-height:1.5; }
    .pillar-dot { width:8px; height:8px; border-radius:50%; background:var(--teal); flex-shrink:0; margin-top:6px; }

    /* PRICING */
    .pricing { background:var(--navy); }
    .pricing .section-title { color:var(--white); }
    .pricing .section-label { color:var(--teal-light); }
    .pricing .section-sub { color:rgba(255,255,255,.65); margin:0 auto; }
    .pricing-cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.5rem; margin-top:2.8rem; }
    .price-card { background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12); border-radius:var(--radius); padding:2rem 1.8rem; }
    .price-card.featured { background:rgba(0,180,216,.12); border-color:rgba(0,180,216,.4); }
    .price-icon { width:48px; height:48px; border-radius:12px; background:rgba(0,180,216,.18); display:flex; align-items:center; justify-content:center; margin-bottom:1.2rem; }
    .price-badge { display:inline-block; background:var(--teal); color:var(--navy-dark); font-size:.75rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; padding:.25rem .7rem; border-radius:4px; margin-bottom:.8rem; }
    .price-card h3 { font-size:1.05rem; font-weight:700; color:var(--white); margin-bottom:.5rem; }
    .price-amount { font-size:2.4rem; font-weight:900; color:var(--teal); line-height:1; margin-bottom:.3rem; }
    .price-sub { font-size:.85rem; color:rgba(255,255,255,.5); margin-bottom:1rem; }
    .price-card p { font-size:.9rem; color:rgba(255,255,255,.7); line-height:1.65; }
    .pricing-note { margin-top:2rem; text-align:center; font-size:.88rem; color:rgba(255,255,255,.45); }

    /* ECOSYSTEM */
    .ecosystem { background:var(--off-white); text-align:center; padding:3rem 2rem; }
    .ecosystem p { color:var(--gray-500); font-size:.95rem; margin-bottom:.8rem; }
    .eco-badges { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:1rem; }
    .eco-badge { background:var(--white); border:1.5px solid var(--gray-300); border-radius:8px; padding:.5rem 1.2rem; font-size:.85rem; font-weight:600; color:var(--navy); }

    /* CTA BANNER */
    .cta-banner { background:linear-gradient(135deg, var(--teal-dark) 0%, var(--teal) 100%); text-align:center; padding:4.5rem 2rem; }
    .cta-banner h2 { font-size:clamp(1.6rem,3vw,2.2rem); font-weight:800; color:var(--navy-dark); margin-bottom:.8rem; }
    .cta-banner p { color:rgba(15,30,49,.7); font-size:1.05rem; margin-bottom:2rem; max-width:520px; margin-left:auto; margin-right:auto; }
    .btn-dark { background:var(--navy); color:var(--white); border:none; padding:.9rem 2.2rem; border-radius:8px; font-size:1rem; font-weight:700; cursor:pointer; text-decoration:none; display:inline-block; transition:background .2s, transform .15s; }
    .btn-dark:hover { background:var(--navy-dark); transform:translateY(-2px); }

    /* FOOTER */
    footer { background:var(--navy-dark); color:rgba(255,255,255,.5); padding:3rem 2rem 2rem; }
    .footer-grid { max-width:1080px; margin:0 auto; display:grid; grid-template-columns:2fr 1fr 1fr; gap:2rem; margin-bottom:2.5rem; }
    @media (max-width:640px) { .footer-grid { grid-template-columns:1fr; } }
    .footer-brand { display:flex; align-items:center; gap:12px; margin-bottom:.8rem; }
    .footer-brand-name { color:var(--white); font-weight:700; font-size:1rem; }
    .footer-desc { font-size:.85rem; line-height:1.65; max-width:260px; }
    .footer-col h4 { color:var(--white); font-size:.9rem; font-weight:700; margin-bottom:.8rem; }
    .footer-col a { display:block; color:rgba(255,255,255,.5); text-decoration:none; font-size:.85rem; margin-bottom:.4rem; transition:color .2s; }
    .footer-col a:hover { color:var(--teal-light); }
    .footer-bottom { max-width:1080px; margin:0 auto; border-top:1px solid rgba(255,255,255,.08); padding-top:1.4rem; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.5rem; font-size:.8rem; }

    /* REGISTER */
    .register-page { background:var(--off-white); min-height:calc(100vh - 68px); display:flex; align-items:center; justify-content:center; padding:3rem 1rem; }
    .register-wrap { width:100%; max-width:520px; }
    .register-card { background:var(--white); border-radius:14px; padding:2.8rem 2.4rem; box-shadow:var(--shadow-lg); border:1px solid var(--gray-100); }
    .register-card h2 { font-size:1.7rem; font-weight:800; color:var(--navy); margin-bottom:.3rem; }
    .register-card .sub { color:var(--gray-500); font-size:.92rem; margin-bottom:2rem; }
    .form-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    @media (max-width:480px) { .form-row { grid-template-columns:1fr; } }
    .field { display:flex; flex-direction:column; gap:.4rem; margin-bottom:1rem; }
    .field label { font-size:.85rem; font-weight:600; color:var(--gray-700); }
    .field input, .field select { border:1.5px solid var(--gray-300); border-radius:7px; padding:.65rem .85rem; font-size:.95rem; color:var(--text); outline:none; font-family:inherit; background:var(--white); transition:border-color .2s, box-shadow .2s; }
    .field input:focus, .field select:focus { border-color:var(--teal); box-shadow:0 0 0 3px rgba(0,180,216,.15); }
    .role-select { appearance:none; cursor:pointer; }
    .checkbox-row { display:flex; align-items:flex-start; gap:.6rem; margin-bottom:1.4rem; font-size:.85rem; color:var(--gray-700); }
    .checkbox-row input[type="checkbox"] { margin-top:3px; accent-color:var(--teal); flex-shrink:0; }
    .checkbox-row a { color:var(--teal-dark); }
    .btn-submit { width:100%; background:var(--teal); color:var(--navy-dark); border:none; padding:.9rem; border-radius:8px; font-size:1rem; font-weight:700; cursor:pointer; font-family:inherit; transition:background .2s, transform .15s; }
    .btn-submit:hover { background:var(--teal-dark); transform:translateY(-1px); }
    .register-back { text-align:center; margin-top:1.2rem; font-size:.88rem; color:var(--gray-500); }
    .register-back a { color:var(--teal-dark); text-decoration:none; font-weight:600; }
    .or-divider { text-align:center; color:var(--gray-300); font-size:.8rem; margin:1.4rem 0; position:relative; }
    .or-divider::before, .or-divider::after { content:''; position:absolute; top:50%; width:calc(50% - 32px); height:1px; background:var(--gray-100); }
    .or-divider::before { left:0; } .or-divider::after { right:0; }
    .btn-assessment-link { display:block; width:100%; text-align:center; background:var(--off-white); color:var(--navy); border:1.5px solid var(--gray-300); padding:.75rem; border-radius:8px; font-size:.92rem; font-weight:600; text-decoration:none; transition:border-color .2s, background .2s; }
    .btn-assessment-link:hover { border-color:var(--teal); background:rgba(0,180,216,.05); }
    .success-box { text-align:center; padding:1.5rem 0; }
    .success-icon { width:68px; height:68px; border-radius:50%; background:linear-gradient(135deg, var(--teal) 0%, #0077a8 100%); display:flex; align-items:center; justify-content:center; margin:0 auto 1.2rem; }
    .success-box h3 { font-size:1.4rem; font-weight:800; color:var(--navy); margin-bottom:.6rem; }
    .success-box p { color:var(--gray-500); font-size:.95rem; margin-bottom:1.4rem; line-height:1.65; }

    /* FAQ */
    .faq-page { background:var(--off-white); min-height:calc(100vh - 68px); padding:4rem 2rem 5rem; }
    .faq-inner { max-width:760px; margin:0 auto; }
    .faq-page h2 { font-size:clamp(1.8rem,3.5vw,2.6rem); font-weight:800; color:var(--navy); margin-bottom:.4rem; }
    .faq-sub { color:var(--gray-500); font-size:1rem; margin-bottom:2.5rem; }
    .faq-section-head { font-size:.8rem; font-weight:700; color:var(--teal-dark); text-transform:uppercase; letter-spacing:.1em; margin:2rem 0 .8rem; }
    .faq-list { display:flex; flex-direction:column; gap:.6rem; }
    .faq-item { background:var(--white); border-radius:var(--radius); border:1px solid var(--gray-100); overflow:hidden; box-shadow:0 2px 8px rgba(27,42,74,.06); }
    .faq-q { width:100%; text-align:left; padding:1.1rem 1.4rem; display:flex; align-items:center; justify-content:space-between; background:none; border:none; cursor:pointer; font-size:.95rem; font-weight:700; color:var(--navy); font-family:inherit; transition:background .15s; }
    .faq-q:hover { background:var(--off-white); }
    .faq-q.open { color:var(--teal-dark); }
    .faq-chevron { width:20px; height:20px; flex-shrink:0; margin-left:1rem; color:var(--gray-500); transition:transform .25s; }
    .faq-q.open .faq-chevron { transform:rotate(180deg); color:var(--teal-dark); }
    .faq-a { max-height:0; overflow:hidden; padding:0 1.4rem; font-size:.93rem; color:var(--gray-700); line-height:1.72; transition:max-height .3s ease, padding .2s; }
    .faq-a.open { max-height:400px; padding:0 1.4rem 1.3rem; }

    /* HOW WE WORK PAGE */
    .hww-page { background:var(--off-white); min-height:calc(100vh - 68px); padding:4rem 2rem 5rem; }
    .hww-inner { max-width:800px; margin:0 auto; }

    @media (max-width:600px) {
      nav { padding:0 1rem; }
      .nav-links { gap:.8rem; }
      .footer-bottom { flex-direction:column; text-align:center; }
    }
  </style>
</head>
<body>

<!-- ─── SHARED SVG DEFS ─── -->
<svg style="display:none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Platypus mark: teal circle + white silhouette -->
    <symbol id="icon-platypus" viewBox="0 0 48 48">
      <circle cx="24" cy="24" r="24" fill="#00b4d8"/>
      <!-- body -->
      <ellipse cx="27" cy="28" rx="12" ry="8.5" fill="#0f1e31"/>
      <!-- head -->
      <circle cx="15" cy="23" r="7.5" fill="#0f1e31"/>
      <!-- bill -->
      <path d="M9 25C6 23 4.5 27 7 29C9.5 31 15.5 27.5 15.5 26C15.5 24 12 24 9 25Z" fill="#0f1e31"/>
      <!-- tail -->
      <path d="M37 29C42 25 44 32 41 34C38.5 36 37 31.5 37 29Z" fill="#0f1e31"/>
      <!-- feet -->
      <ellipse cx="21" cy="36" rx="4" ry="2" fill="#0f1e31"/>
      <ellipse cx="30" cy="36.5" rx="4" ry="2" fill="#0f1e31"/>
      <!-- eye white -->
      <circle cx="12.5" cy="20.5" r="2.8" fill="white"/>
      <!-- pupil -->
      <circle cx="12" cy="20" r="1.1" fill="#0f1e31"/>
    </symbol>

    <!-- No Resumes icon: document with bold X -->
    <symbol id="icon-noresume" viewBox="0 0 28 28">
      <rect x="5" y="3" width="16" height="21" rx="2.5" fill="none" stroke="white" stroke-width="2"/>
      <path d="M11 3v0a3 3 0 003 3 3 3 0 003-3" fill="none" stroke="white" stroke-width="2"/>
      <line x1="9" y1="15" x2="19" y2="15" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
      <line x1="9" y1="19" x2="15" y2="19" stroke="rgba(255,255,255,0.4)" stroke-width="1.5"/>
      <!-- bold X -->
      <line x1="9" y1="10" x2="19" y2="20" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="19" y1="10" x2="9" y2="20" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
    </symbol>

    <!-- Assessment icon: clipboard with score bars -->
    <symbol id="icon-assessment" viewBox="0 0 28 28">
      <rect x="5" y="5" width="18" height="20" rx="2.5" fill="none" stroke="white" stroke-width="2"/>
      <path d="M10 5v1a4 4 0 004 3 4 4 0 004-3V5" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <!-- bars -->
      <rect x="8"  y="16" width="3" height="5" rx="1" fill="white"/>
      <rect x="12.5" y="13" width="3" height="8" rx="1" fill="white"/>
      <rect x="17" y="18" width="3" height="3" rx="1" fill="white"/>
      <!-- score line -->
      <line x1="8" y1="12" x2="20" y2="12" stroke="rgba(255,255,255,0.35)" stroke-width="1" stroke-dasharray="2 2"/>
    </symbol>

    <!-- Matching icon: two people + center check -->
    <symbol id="icon-match" viewBox="0 0 28 28">
      <!-- person left -->
      <circle cx="5.5" cy="9" r="3" fill="none" stroke="white" stroke-width="2"/>
      <path d="M1 20c0-4 2-6 4.5-6S10 16 10 20" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <!-- person right -->
      <circle cx="22.5" cy="9" r="3" fill="none" stroke="white" stroke-width="2"/>
      <path d="M18 20c0-4 2-6 4.5-6S27 16 27 20" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <!-- center check circle -->
      <circle cx="14" cy="10" r="4.5" fill="white" opacity="0.15" stroke="white" stroke-width="1.5"/>
      <polyline points="11.5 10 13 11.8 16.5 7.5" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </symbol>
  </defs>
</svg>

